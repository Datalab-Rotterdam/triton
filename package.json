{
  "name": "triton",
  "version": "1.0.0",
  "description": "A TypeScript-first, dependency-free API client for the DAMEN Triton REST API",
  "main": "./dist/index.es.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "examples/01_bootstrap_and_metadata": "tsx --env-file=.env examples/01_bootstrap_and_metadata.ts",
    "examples/02_sensor_latest_auto_vessel": "tsx --env-file=.env examples/02_sensor_latest_auto_vessel.ts",
    "examples/03_sensor_readings_explicit_vessel": "tsx --env-file=.env examples/03_sensor_readings_explicit_vessel.ts",
    "examples/04_virtual_and_data": "tsx --env-file=.env examples/04_virtual_and_data.ts",
    "examples/05_token_manual_control": "tsx --env-file=.env examples/05_token_manual_control",
    "examples/06_get_all_sensors": "tsx --env-file=.env examples/06_get_all_sensors.ts",
    "docs:build": "typedoc src/index.ts --out generated/docs --name \"triton\" --theme default --excludePrivate --excludeProtected"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DataLab-Rotterdam/triton.git"
  },
  "keywords": [
    "triton",
    "damen",
    "vessels"
  ],
  "author": "A.P.A. Slaa",
  "license": "Apache-2.0",
  "type": "module",
  "bugs": {
    "url": "https://github.com/DataLab-Rotterdam/triton/issues"
  },
  "homepage": "datalab-rotterdam.github.io/triton/",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.3",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^25.0.9",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.0.17",
    "tsx": "^4.20.4",
    "typedoc": "^0.28.16",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.17"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "CHANGELOG.md"
          ],
          "message": "triton(release): 🚀 ${nextRelease.version} \n\n${nextRelease.notes}"
        }
      ]
    ]
  }
}
